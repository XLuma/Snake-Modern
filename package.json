{
  "name": "snake-modern",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "compile": "tsc -b tsconfig.build.json",
    "start": "cd ./server && npm start",
    "start:server": "cd ./server && npm run start:watch",
    "start:client": "cd ./client && npm run dev",
    "dev": "concurrently --prefix \"{name}\" --names \"server,client\" -c \"bgMagenta.bold,bgBlue.bold\" \"npm run start:server\" \"npm run start:client\"",
    "studio": "cd ./server && npm run studio",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "engines": {
    "node": ">=22"
  },
  "workspaces": {
    "packages": [
      "client/",
      "server/",
      "prisma/"
    ]
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "concurrently": "^9.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
